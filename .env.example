# OTranslator API secret key (required for all calls)
# Issue / view at: https://otranslator.com/en/developer
OTRANSLATOR_API_KEY=

# Optional: override base URL (default: https://otranslator.com/api)
# OTRANSLATOR_BASE_URL=https://otranslator.com/api

# Optional: request timeout in milliseconds (default: 60000)
# OTRANSLATOR_TIMEOUT_MS=60000
