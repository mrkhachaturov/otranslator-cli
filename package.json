{
  "name": "otranslator-cli",
  "version": "0.1.1",
  "description": "Unofficial TypeScript SDK and CLI for the OTranslator API — AI document/text translation for 50+ formats and 100+ languages",
  "type": "module",
  "private": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./errors": {
      "types": "./dist/errors.d.ts",
      "import": "./dist/errors.js",
      "require": "./dist/errors.cjs"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "otcli": "./dist/cli/index.js"
  },
  "files": [
    "dist/",
    "openapi.json",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run -c vitest.e2e.config.ts",
    "test:e2e:paid": "OTRANSLATOR_E2E_PAID=1 vitest run -c vitest.e2e.config.ts",
    "test:all": "npm run test && npm run test:e2e",
    "cli": "tsx src/cli/index.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm run typecheck && npm run lint && npm run format:check && npm run test",
    "prepare": "husky",
    "prepublishOnly": "npm run check && npm run build"
  },
  "lint-staged": {
    "*.{ts,js,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mrkhachaturov/otranslator-cli.git"
  },
  "keywords": [
    "otranslator",
    "translation",
    "translate",
    "ai-translation",
    "document-translation",
    "pdf-translation",
    "subtitle-translation",
    "epub-translation",
    "cli",
    "sdk",
    "typescript",
    "api-client"
  ],
  "author": "Ruben Khachaturov <mr.kha4a2rov@protonmail.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/mrkhachaturov/otranslator-cli/issues"
  },
  "homepage": "https://github.com/mrkhachaturov/otranslator-cli#readme",
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "dotenv": "^16.4.7",
    "eslint": "^9.16.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-n": "^17.15.0",
    "globals": "^15.13.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.11",
    "prettier": "^3.4.2",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vitest": "^2.1.8"
  }
}
